{{ ansible_managed | comment }}

api:
  insecure: true
  dashboard: true

providers:
  http:
    endpoint: "http://{{ pangolin_name }}:3001/api/v1/traefik-config"
    pollInterval: 5s
  file:
    filename: /etc/traefik/dynamic_config.yml

experimental:
  plugins:
    badger:
      moduleName: github.com/fosrl/badger
      version: v1.3.1

log:
  level: "{{ pangolin_traefik_log_level | upper }}"
  format: common
  maxSize: 100
  maxBackups: 3
  maxAge: 3
  compress: true

certificatesResolvers:
  letsencrypt:
    acme:
      httpChallenge:
        entryPoint: web
      email: "{{ pangolin_traefik_letsencrypt_email }}"
      storage: /letsencrypt/acme.json
      caServer: "https://acme-v02.api.letsencrypt.org/directory"

entryPoints:
  web:
    address: ":80"
  websecure:
    address: ":443"
    transport:
      respondingTimeouts:
        readTimeout: "30m"
    http:
      tls:
        certResolver: letsencrypt
      encodedCharacters:
        allowEncodedSlash: true
        allowEncodedQuestionMark: true
{% for port in pangolin_gerbil_ports_extra %}
{% set listen_port = port.split(':')[0].split('/')[0] %}
{% set protocol = (port.split('/')[-1] | lower) if ('/' in port) else 'tcp' %}
  {{ protocol }}-{{ listen_port }}:
    address: ":{{ listen_port }}/{{ protocol }}"
{% endfor %}


serversTransport:
  insecureSkipVerify: true

ping:
  entryPoint: "web"
